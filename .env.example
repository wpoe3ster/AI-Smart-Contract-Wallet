# .env.example

# Environment variables for EVM networks and API keys

# Ethereum network
ETH_NODE_URL=<Your Ethereum Node URL>

# Binance Smart Chain network
BSC_NODE_URL=<Your BSC Node URL>

# Polygon network
POLYGON_NODE_URL=<Your Polygon Node URL>

# API Keys

# Etherscan API Key
ETHERSCAN_API_KEY=<Your Etherscan API Key>

# Infura Project ID
INFURA_PROJECT_ID=<Your Infura Project ID>

# Alchemy API Key
ALCHEMY_API_KEY=<Your Alchemy API Key>
